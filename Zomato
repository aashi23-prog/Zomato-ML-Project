        "# ============================================================\n",
        "# Recommendation System - Function\n",
        "# Description: Function that takes a restaurant name and\n",
        "# returns top 5 most similar restaurants using cosine similarity\n",
        "# ============================================================\n",
        "\n",
        "def recommend_restaurants(restaurant_name, top_n=5):\n",
        "    try:\n",
        "        # Get index of the restaurant\n",
        "        restaurant_list = df_master_clean['Name'].tolist()\n",
        "\n",
        "        if restaurant_name not in restaurant_list:\n",
        "            print(f\"Restaurant '{restaurant_name}' not found!\")\n",
        "            print(f\"Available restaurants include: {restaurant_list[:5]}\")\n",
        "            return\n",
        "\n",
        "        idx = restaurant_list.index(restaurant_name)\n",
        "\n",
        "        # Get similarity scores for this restaurant\n",
        "        sim_scores = list(enumerate(cosine_sim_matrix[idx]))\n",
        "\n",
        "        # Sort by similarity score descending\n",
        "        sim_scores = sorted(sim_scores, key=lambda x: x[1], reverse=True)\n",
        "\n",
        "        # Get top N (excluding itself)\n",
        "        sim_scores = sim_scores[1:top_n+1]\n",
        "\n",
        "        # Get restaurant details\n",
        "        recommended_indices = [i[0] for i in sim_scores]\n",
        "        recommended_scores = [i[1] for i in sim_scores]\n",
        "\n",
        "        result = df_master_clean.iloc[recommended_indices][['Name', 'Cost', 'Avg_Rating', 'Primary_Cuisine', 'Cluster_Label']].copy()\n",
        "        result['Similarity_Score'] = [round(s, 4) for s in recommended_scores]\n",
        "\n",
        "        print(f\"Top {top_n} Restaurants Similar to '{restaurant_name}':\")\n",
        "        print(\"=\" * 60)\n",
        "        display(result)\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f\"Error: {e}\")\n",
        "\n",
        "# Test with a popular restaurant\n",
        "recommend_restaurants('Paradise')"
