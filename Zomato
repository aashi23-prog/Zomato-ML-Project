        "# ============================================================\n",
        "# Restaurant Success Score - Calculate Score\n",
        "# Description: Applying the weighted formula to calculate\n",
        "# final success score for each restaurant\n",
        "# Success Score = 0.4*rating + 0.3*reviews + 0.2*sentiment + 0.1*pictures\n",
        "# ============================================================\n",
        "\n",
        "df_success['Success_Score'] = (\n",
        "    0.4 * df_success['Rating_Norm'] +\n",
        "    0.3 * df_success['Reviews_Norm'] +\n",
        "    0.2 * df_success['Sentiment_Norm'] +\n",
        "    0.1 * df_success['Pictures_Norm']\n",
        ")\n",
        "\n",
        "# Scale to 0-100 for readability\n",
        "df_success['Success_Score'] = (df_success['Success_Score'] * 100).round(2)\n",
        "\n",
        "# Rank restaurants\n",
        "df_success['Rank'] = df_success['Success_Score'].rank(ascending=False).astype(int)\n",
        "df_success = df_success.sort_values('Success_Score', ascending=False)\n",
        "\n",
        "print(\"Success Scores calculated!\")\n",
        "print(\"\\nTop 10 Restaurants by Success Score:\")\n",
        "print(\"=\" * 60)\n",
        "display(df_success[['Rank', 'Name', 'Cost', 'Avg_Rating',\n",
        "                     'Success_Score', 'Cluster_Label']].head(10))"
