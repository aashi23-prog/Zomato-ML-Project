        "# ============================================================\n",
        "# Hypothesis Test 4\n",
        "# Do restaurants open late night get lower ratings?\n",
        "# H0: Timing has no effect on rating\n",
        "# H1: Late night restaurants get different ratings\n",
        "# ============================================================\n",
        "\n",
        "# Tag restaurants as late night or not\n",
        "df_merged['Is_LateNight'] = df_merged['Timings'].str.contains(\n",
        "    '11 PM|12 AM|1 AM|2 AM|midnight', case=False, na=False)\n",
        "\n",
        "late_night_ratings = df_merged[df_merged['Is_LateNight'] == True]['Avg_Rating'].dropna()\n",
        "normal_ratings = df_merged[df_merged['Is_LateNight'] == False]['Avg_Rating'].dropna()\n",
        "\n",
        "t_stat, p_value4 = stats.ttest_ind(late_night_ratings, normal_ratings)\n",
        "\n",
        "print(\"HYPOTHESIS TEST 4: Late Night Restaurants vs Rating\")\n",
        "print(\"=\" * 50)\n",
        "print(f\"Late Night Avg Rating: {late_night_ratings.mean():.4f}\")\n",
        "print(f\"Normal Hours Avg Rating: {normal_ratings.mean():.4f}\")\n",
        "print(f\"T-Statistic: {t_stat:.4f}\")\n",
        "print(f\"P-Value: {p_value4:.4f}\")\n",
        "print()\n",
        "\n",
        "if p_value4 < 0.05:\n",
        "    print(\"Result: REJECT H0 — Late night timing significantly affects rating\")\n",
