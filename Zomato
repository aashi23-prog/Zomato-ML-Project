        "# ============================================================\n",
        "# Restaurant Success Score - Setup\n",
        "# Description: Creating a composite success score for each\n",
        "# restaurant combining rating, reviews, sentiment and pictures\n",
        "# Formula: 0.4×rating + 0.3×review_count + 0.2×sentiment + 0.1×pictures\n",
        "# ============================================================\n",
        "\n",
        "# First get average sentiment score per restaurant\n",
        "sentiment_per_restaurant = df_reviews.groupby('Restaurant').agg(\n",
        "    Avg_Sentiment=('VADER_Score', 'mean'),\n",
        "    Avg_Pictures_Review=('Pictures', 'mean')\n",
        ").reset_index()\n",
        "sentiment_per_restaurant.columns = ['Name', 'Avg_Sentiment', 'Avg_Pictures_Review']\n",
        "\n",
        "# Merge into master clean\n",
        "df_success = df_master_clean.merge(sentiment_per_restaurant, on='Name', how='left')\n",
        "\n",
        "print(\"Sentiment merged into master dataframe!\")\n",
        "print(f\"Shape: {df_success.shape}\")\n",
        "display(df_success[['Name', 'Avg_Rating', 'Total_Reviews', 'Avg_Sentiment', 'Avg_Pictures_Review']].head())"
