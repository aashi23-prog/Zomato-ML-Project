        "# ============================================================\n",
        "# Feature Engineering - Create Cost Category - FIXED\n",
        "# Description: Creating Cost_Category directly in df_master\n",
        "# and encoding it as numerical values for ML model\n",
        "# ============================================================\n",
        "\n",
        "# Create Cost_Category in df_master directly\n",
        "df_master['Cost_Category'] = pd.cut(df_master['Cost'],\n",
        "                                     bins=[0, 500, 1000, 1500, 3000],\n",
        "                                     labels=['Budget', 'Mid-Range', 'Premium', 'Luxury'])\n",
        "\n",
        "# Encode it numerically\n",
        "cost_mapping = {'Budget': 1, 'Mid-Range': 2, 'Premium': 3, 'Luxury': 4}\n",
        "df_master['Cost_Category_Encoded'] = df_master['Cost_Category'].map(cost_mapping)\n",
        "\n",
        "print(\"Cost category created and encoded!\")\n",
        "display(df_master[['Name', 'Cost', 'Cost_Category', 'Cost_Category_Encoded']].head())"
